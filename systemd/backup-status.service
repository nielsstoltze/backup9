[Unit]
Description=backup9 status API (FastAPI)
After=network-online.target zfs-unlock-backup.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/backup9/status-api
ExecStart=/opt/backup9/status-api/.venv/bin/uvicorn main:app \
    --host 0.0.0.0 --port 8094 --workers 1 --log-level info
Restart=on-failure
RestartSec=3
User=local_admin

[Install]
WantedBy=multi-user.target
